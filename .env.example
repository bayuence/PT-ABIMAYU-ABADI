# =========================================
# ENVIRONMENT VARIABLES - PT. Abimayu Abadi
# =========================================
# Salin file ini menjadi .env.local untuk development lokal
# Di hosting/server, masukkan nilai ini melalui panel kontrol hosting

# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (RAHASIA - jangan dibagikan!)
SANITY_API_READ_TOKEN=your_sanity_read_token_here
